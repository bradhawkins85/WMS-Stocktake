# ──────────────────────────────────────────────────────────────────────────────
# WMS Stocktake – environment variable template
# Copy this file to .env and fill in the required values before running deploy.sh
# ──────────────────────────────────────────────────────────────────────────────

# --- App URL (must match the public URL used to access the app) ---------------
NEXTAUTH_URL=http://localhost:3000

# --- Secret used to sign JWTs (generate with: openssl rand -base64 32) --------
# deploy.sh will generate this automatically if left blank.
NEXTAUTH_SECRET=

# --- Port the app is exposed on (default: 3000) --------------------------------
PORT=3000

# --- Datapel integration (optional) -------------------------------------------
DATAPEL_API_URL=
DATAPEL_API_KEY=
